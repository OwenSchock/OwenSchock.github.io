---
interface Props {
  url: string;
}
const { url } = Astro.props;
---

<div class="relative w-full h-[600px] md:h-[800px] rounded-xl border border-slate-800 bg-slate-900 shadow-2xl overflow-hidden group">
  <iframe 
    src={url}
    class="absolute top-0 left-0 w-full h-full"
    frameborder="0" 
    allowfullscreen
  ></iframe>
</div>